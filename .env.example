# ── AI / LLM ──────────────────────────────────────────────────────────────────
# Required: powers all CrewAI agents (GPT-4o for HIGH fidelity, claude-haiku for LOW)
OPENAI_API_KEY=sk-...

# ── Web search (Serper) ────────────────────────────────────────────────────────
# Required: used by the market analyser and news sentiment agents
# Get a free key at https://serper.dev
SERPER_API_KEY=your_serper_api_key_here

# ── Dune Analytics ────────────────────────────────────────────────────────────
# Required only for HIGH fidelity mode (on-chain data analyst agent)
# Get a key at https://dune.com/settings/api
DUNE_API_KEY=your_dune_api_key_here
