# Python backend URL (defaults to http://localhost:8000 if not set)
AGENT_API_URL=http://localhost:8000

# Sui network: testnet | mainnet | devnet (defaults to testnet)
SUI_NETWORK=testnet

# Sui on-chain object IDs (required for execute and dao-override routes)
SUI_PACKAGE_ID=0x...
SUI_RISK_PARAMS_ID=0x...
GUARDIAN_CAP_ID=0x...
DAO_CAP_ID=0x...

# Guardian keypair in suiprivkey... format (required for on-chain execution)
GUARDIAN_PRIVATE_KEY=suiprivkey1...
